# Example configuration for @ondewo/csi-client-nodejs examples.
#
# This is a NON-SECRET template: fill in real values locally, never commit secrets.
# Every example loads this file via dotenv (path relative to the script), so the
# working directory does not matter. Variable names follow the canonical ONDEWO
# scheme shared across all ONDEWO client SDKs — one name per concept, no synonyms.

# --- Connection -------------------------------------------------------------
# Host and port of the CSI gRPC server.
ONDEWO_HOST=localhost
ONDEWO_PORT=50055

# --- Secure channel ---------------------------------------------------------
# Use a TLS gRPC channel (true) or an insecure one (false).
ONDEWO_USE_SECURE_CHANNEL=false
# Optional path to a PEM root-certificate file for the TLS channel.
# Leave blank to use the system trust store (only read when the channel is secure).
ONDEWO_GRPC_CERT=

# --- Keycloak authentication ------------------------------------------------
# Bearer-token login (Resource-Owner-Password-Credentials) against Keycloak.
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-nlu-cai-sdk-public
# Only needed for confidential clients; leave blank for the public SDK client.
KEYCLOAK_CLIENT_SECRET=
# Technical-user (2FA-exempt) credentials.
KEYCLOAK_USER_NAME=
KEYCLOAK_PASSWORD=
# Verify the Keycloak server TLS certificate (set to false only for self-signed local setups).
KEYCLOAK_VERIFY_SSL=true
